---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CosmicBackground from "@/components/celestial/CosmicBackground";
import AppHeader from "@/components/celestial/AppHeader.astro";
import SiteHeader from "@/components/celestial/SiteHeader.astro";
import UrlParamsSync from "@/components/ui/UrlParamsSync.astro";
import NotificationOptIn from "@/components/ui/NotificationOptIn.astro";
import PwaInstallPrompt from "@/components/ui/PwaInstallPrompt.astro";
import VisualSanctuarySwitcher from "@/components/celestial/VisualSanctuarySwitcher";
import { VerseCard } from "@/components/verse/VerseCard";
import { getSsgInitialVerse } from "@/lib/providers/verseServiceFactory";
import type { Lang, Mood } from "@/lib/domain/types";

const buildLang: Lang = "es";
const buildMood: Mood = "all";
const initial = getSsgInitialVerse(buildLang, buildMood);
const year = new Date().getFullYear();
---

<BaseLayout
  title="Versículos Bíblicos — Meditación bíblica"
  description="Medita, ora y descarga un versículo. Español e inglés, categorías y API bíblica con respaldo local."
  lang="es"
>
  <CosmicBackground client:idle />
  <SiteHeader currentLang="es" currentMood="all" />
  <main
    class="pointer-events-auto relative z-10 mx-auto flex min-h-dvh w-full max-w-3xl flex-col px-3 pb-8 pt-[calc(5rem+env(safe-area-inset-top,0px))] sm:px-4 sm:pt-[calc(5.25rem+env(safe-area-inset-top,0px))] md:px-6 md:pb-10 md:pt-[calc(6rem+env(safe-area-inset-top,0px))] lg:px-8"
  >
    <div class="shrink-0 border-b border-gold-500/5 pb-3 sm:pb-4">
      <AppHeader />
    </div>
    <div
      class="mt-0 flex min-h-0 w-full flex-1 flex-col items-center justify-center py-2 sm:py-3"
    >
      <div class="w-full max-w-2xl">
        <VerseCard client:load initialFromBuild={initial} />
      </div>
    </div>
    <footer class="mt-6 border-t border-gold-500/15 pt-3 text-center text-xs text-gold-300/70 sm:mt-8 sm:pt-4 sm:text-sm">
      <div class="mb-2 flex items-center justify-center">
        <img
          src="/img/logo-refugio-celestial-best.png"
          alt="Logo Refugio Celestial"
          class="h-8 w-8 rounded-full border border-gold-500/30 object-cover sm:h-9 sm:w-9"
          loading="lazy"
        />
      </div>
      <span>© {year} Versículos Bíblicos · </span>
      <span class="i18n-es">Desarrollado por </span>
      <span class="i18n-en hidden" aria-hidden="true">Developed by </span>
      <a
        href="https://sysjol.onrender.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="font-semibold text-gold-300 transition hover:text-gold-200 hover:underline"
      >
        SysJoL
      </a>
    </footer>
  </main>
  <UrlParamsSync />
  <NotificationOptIn />
  <PwaInstallPrompt />
  <VisualSanctuarySwitcher client:load />
</BaseLayout>
