<div
  id="refugio-connection-badge"
  class="opacity-0 transition-opacity duration-150 inline-flex items-center gap-1.5 rounded-full border border-gold-500/35 bg-black/35 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-gold-200/85"
  aria-live="polite"
>
  <span
    class="h-1.5 w-1.5 rounded-full bg-emerald-300 shadow-[0_0_6px_rgba(110,231,183,0.75)]"
    data-conn-dot
    aria-hidden="true"
  ></span>
  <span class="i18n-es" data-conn-label>Online</span>
  <span class="i18n-en hidden" data-conn-label-en aria-hidden="true">Online</span>
</div>

<script is:inline>
  (function () {
    const badge = document.getElementById("refugio-connection-badge");
    if (!badge) return;
    const dot = badge.querySelector("[data-conn-dot]");
    const es = badge.querySelector("[data-conn-label]");
    const en = badge.querySelector("[data-conn-label-en]");

    const apply = () => {
      const on = navigator.onLine;
      if (es) es.textContent = on ? "Online" : "Offline";
      if (en) en.textContent = on ? "Online" : "Offline";
      if (!dot) return;
      if (on) {
        dot.style.backgroundColor = "rgb(110 231 183)";
        dot.style.boxShadow = "0 0 6px rgba(110,231,183,0.75)";
      } else {
        dot.style.backgroundColor = "rgb(253 164 175)";
        dot.style.boxShadow = "0 0 6px rgba(253,164,175,0.7)";
      }
    };

    apply();
    badge.classList.remove("opacity-0");
    window.addEventListener("online", apply);
    window.addEventListener("offline", apply);
  })();
</script>
