---
import type { Lang, Mood } from "@/lib/domain/types";
import { UI } from "@/lib/i18n/labels";
import MobileBottomSheet from "@/components/ui/MobileBottomSheet.astro";

interface Props {
  currentLang: Lang;
  currentMood: Mood;
}

const { currentLang, currentMood } = Astro.props;
const L = UI[currentLang].mood;

const moods: { id: Mood; icon: string }[] = [
  { id: "all", icon: "fa-infinity" },
  { id: "comfort", icon: "fa-dove" },
  { id: "wisdom", icon: "fa-lightbulb" },
  { id: "hope", icon: "fa-star" },
  { id: "love", icon: "fa-heart" },
  { id: "repentance", icon: "fa-hands-praying" },
];
const moodLabel = currentLang === "es" ? "Categoría" : "Mood";
const mobileFilterLabel = currentLang === "es" ? "Filtrar categorías" : "Filter categories";
---

<div class="w-full min-w-0 md:flex md:w-full md:justify-center">
  <form
    method="get"
    action=""
    class="moodbar-mobile flex justify-center md:hidden"
    id="refugio-mood-form-m"
  >
    <input type="hidden" name="lang" class="refugio-mood-lang" value={currentLang} />
    <input type="hidden" name="mood" id="refugio-mood-mobile-value" value={currentMood} />

    <button
      type="button"
      id="refugio-mood-open"
      data-mood-open
      class="focus-ring inline-flex h-10 w-10 items-center justify-center rounded-full border border-gold-500/45 bg-black/45 text-gold-200 ring-1 ring-inset ring-white/5 backdrop-blur-sm transition hover:border-gold-500/60 hover:bg-black/55"
      aria-label={moodLabel}
      aria-haspopup="dialog"
      aria-expanded="false"
      title={mobileFilterLabel}
      onclick="(function(){var s=document.getElementById('refugio-mood-sheet');var b=document.getElementById('refugio-mood-open');if(s){s.classList.remove('hidden');s.setAttribute('aria-hidden','false');}if(b){b.setAttribute('aria-expanded','true');}})()"
    >
      <i class="fa-solid fa-filter text-sm text-gold-300/95" aria-hidden="true" />
      <span class="sr-only">{mobileFilterLabel}</span>
    </button>

    <MobileBottomSheet
      id="refugio-mood-sheet"
      title={moodLabel}
      closeLabel={currentLang === "es" ? "Cerrar" : "Close"}
      maxHeightClass="max-h-[72dvh]"
    >
      {
        moods.map((m) => (
          <button
            type="button"
            data-mood-sheet-btn={m.id}
            class={`focus-ring mood-sheet-option relative flex min-h-11 items-center justify-between rounded-xl border px-3 py-2 text-left transition active:scale-[0.99] ${
              m.id === currentMood
                ? "border-gold-400/70 bg-gold-500/18 text-gold-100"
                : "border-gold-500/25 bg-white/[0.02] text-gold-100 hover:border-gold-500/40 hover:bg-white/[0.04]"
            }`}
            onclick={`(function(v){var h=document.getElementById('refugio-mood-mobile-value');if(h){h.value=v;}var f=document.getElementById('refugio-mood-form-m');if(f){f.submit();}})('${m.id}')`}
          >
            <span class="inline-flex items-center gap-2">
              <i class={`fa-solid ${m.icon} text-[0.78rem] text-gold-300/90`} aria-hidden="true" />
              <span data-mood-sheet-label={m.id} class="text-[13px] font-medium">{L[m.id]}</span>
            </span>
            <i class="fa-solid fa-circle-check text-[0.8rem] text-gold-300/90 opacity-0 transition-opacity" data-mood-sheet-check={m.id} aria-hidden="true" />
          </button>
        ))
      }
    </MobileBottomSheet>
  </form>

  <nav
    class="moodbar-scroll pointer-events-auto hidden min-w-0 overflow-x-auto overflow-y-hidden py-1 [scrollbar-width:thin] md:block md:w-max md:max-w-[min(100vw-8rem,52rem)] md:px-1"
    aria-label="Categoría de versículo"
  >
    <form
      id="refugio-mood-form-d"
      method="get"
      class="mx-auto flex w-max min-w-0 flex-nowrap items-center justify-center gap-1 md:mx-0 md:gap-1.5 lg:gap-2"
      action=""
    >
      <input type="hidden" name="lang" class="refugio-mood-lang" value={currentLang} />
      {
        moods.map((m) => (
          <button
            type="submit"
            name="mood"
            value={m.id}
            data-mood-btn={m.id}
            class="focus-ring mood-pill inline-flex h-9 shrink-0 items-center gap-1 rounded-full border border-white/18 bg-black/15 px-3 text-[11px] font-medium text-gold-100/85 backdrop-blur-sm transition hover:border-gold-500/35 hover:bg-black/25 md:h-9 md:px-3.5 md:text-xs lg:h-10 lg:px-4 lg:text-[13px]"
          >
            <i class={`fa-solid ${m.icon} text-[0.7rem] opacity-90 md:text-xs`} aria-hidden="true" />
            {L[m.id]}
          </button>
        ))
      }
    </form>
  </nav>
</div>

<style is:global>
  .moodbar-scroll {
    -webkit-overflow-scrolling: touch;
  }
  .moodbar-scroll > form {
    min-width: min-content;
  }
  .moodbar-scroll::-webkit-scrollbar {
    height: 0;
  }
  @media (min-width: 768px) {
    .moodbar-scroll::-webkit-scrollbar {
      height: 3px;
    }
    .moodbar-scroll::-webkit-scrollbar-thumb {
      border-radius: 9999px;
      background: rgba(212, 175, 55, 0.28);
    }
  }
  .refugio-mood-select option {
    background: #0f172a;
    color: #f3e5ab;
  }
  .mood-sheet-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
  }
  .mood-sheet-option.is-active {
    border-color: rgba(232, 197, 71, 0.78) !important;
    background: linear-gradient(180deg, rgba(228, 192, 74, 0.24), rgba(201, 162, 39, 0.18)) !important;
  }
  .mood-sheet-option.is-active [data-mood-sheet-check] {
    opacity: 1;
  }
  [data-mood-open].is-filter-active {
    border-color: rgba(232, 197, 71, 0.78) !important;
    background: linear-gradient(180deg, rgba(228, 192, 74, 0.26), rgba(201, 162, 39, 0.2)) !important;
    color: #f8e9b8 !important;
  }
  [data-mood-open].is-filter-active i {
    color: #f8e9b8 !important;
    filter: drop-shadow(0 0 5px rgba(232, 197, 71, 0.45));
  }
  @media (min-width: 460px) {
    .mood-sheet-body {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

<script is:inline>
  (() => {
    const form = document.getElementById("refugio-mood-form-m");
    const openBtn = document.getElementById("refugio-mood-open");
    const closeBtn = document.getElementById("refugio-mood-sheet-close");
    const sheet = document.getElementById("refugio-mood-sheet");
    const panel = document.getElementById("refugio-mood-sheet-panel");
    const hiddenMood = document.getElementById("refugio-mood-mobile-value");
    if (!form || !openBtn || !closeBtn || !sheet || !panel || !hiddenMood) return;
    let previousBodyOverflow = "";
    let previousBodyTouchAction = "";

    // Move sheet out of header stacking/containing context so fixed positioning is truly viewport-based.
    if (sheet.parentElement !== document.body) {
      document.body.appendChild(sheet);
    }

    const isHidden = () => sheet.classList.contains("hidden");
    const openSheet = () => {
      sheet.classList.remove("hidden");
      sheet.classList.add("flex");
      panel.classList.remove("translate-y-full");
      panel.classList.add("translate-y-0");
      sheet.setAttribute("aria-hidden", "false");
      openBtn.setAttribute("aria-expanded", "true");
      previousBodyOverflow = document.body.style.overflow;
      previousBodyTouchAction = document.body.style.touchAction;
      document.body.style.overflow = "hidden";
      document.body.style.touchAction = "none";
    };
    const closeSheet = () => {
      panel.classList.remove("translate-y-0");
      panel.classList.add("translate-y-full");
      sheet.classList.remove("flex");
      sheet.classList.add("hidden");
      sheet.setAttribute("aria-hidden", "true");
      openBtn.setAttribute("aria-expanded", "false");
      document.body.style.overflow = previousBodyOverflow;
      document.body.style.touchAction = previousBodyTouchAction;
    };

    openBtn.addEventListener("click", openSheet);
    closeBtn.addEventListener("click", closeSheet);
    sheet.addEventListener("click", (ev) => {
      if (ev.target === sheet) closeSheet();
    });
    document.addEventListener("keydown", (ev) => {
      if (ev.key === "Escape" && !isHidden()) closeSheet();
    });

    const refreshActiveState = () => {
      if (!(hiddenMood instanceof HTMLInputElement)) return;
      const current = hiddenMood.value;
      form.querySelectorAll("[data-mood-sheet-btn]").forEach((el) => {
        const v = el.getAttribute("data-mood-sheet-btn");
        el.classList.toggle("is-active", v === current);
      });
      openBtn.classList.toggle("is-filter-active", current !== "all");
    };
    refreshActiveState();

    window.addEventListener("pagehide", () => {
      document.body.style.overflow = previousBodyOverflow;
      document.body.style.touchAction = previousBodyTouchAction;
    });
  })();
</script>
